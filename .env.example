# Interval in seconds
CHECK_INTERVAL=60

# qBittorrent WebUI
QBITTORRENT_URL=http://qbittorrent:8080

# Ping target
PING_HOST=

# Docker container name for IP check
IP_CHECK_CONTAINER=

# Allowed/denied IPs or networks (comma-separated, e.g. "1.2.3.4,10.0.0.0/8")
IP_ALLOWED=
IP_DENIED=

# Web UI port
HTTP_PORT=8090

# ntfy notifications (e.g. https://user:password@ntfy.example.com/topic)
NTFY_URL=

# Log level
LOG_LEVEL=INFO
